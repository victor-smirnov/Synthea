# Copy to env.docker and adjust (env.docker is gitignored).
# docker compose loads it automatically when present.

# --- Optional overrides (compose already sets sensible defaults) ---

# Bind address on the host: default 127.0.0.1:8787 (loopback only).
# To listen on all interfaces: SYNTHEA_MCP_PUBLISH=0.0.0.0:8787
# SYNTHEA_MCP_PUBLISH=127.0.0.1:8787

# Dolt on-disk state (repo + home); must stay on the mounted volume in containers.
# SYNTHEA_MCP_DATA=/data

# Timezone for logs (optional)
# TZ=UTC
